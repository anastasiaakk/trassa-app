# Скопируйте в `.env` в корне my-react-app.

# Включить вход и регистрацию через сервер (JWT cookie). Нужен запущенный API и прокси Vite на /api.
# VITE_USE_AUTH_API=true

# Необязательно: если фронт и API на разных origin (без прокси), укажите базовый URL API.
# VITE_API_URL=https://api.example.com

# Публикация сайта в интернете (домен, nginx, VPS): см. DEPLOY.md и deploy/
