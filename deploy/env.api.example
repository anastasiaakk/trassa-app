# Пример /etc/trassa/api.env на сервере (права 600, root:root).
# Скопируйте и задайте свои значения.

NODE_ENV=production
JWT_SECRET=замените-на-случайную-строку-не-короче-32-символов
PORT=4000
LISTEN_HOST=127.0.0.1
TRUST_PROXY=1

# Origin вашего сайта в браузере (с протоколом), через запятую — если www и без www
CORS_ORIGIN=https://example.com,https://www.example.com
