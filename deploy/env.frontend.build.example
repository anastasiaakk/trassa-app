# Переменные на момент `npm run build` в корне my-react-app (фронт в dist/).
# Скопируйте в .env.production.local или задайте в CI.
#
# Вариант A — фронт и API с одного домена (nginx отдаёт / и проксирует /api):
#   VITE_API_URL не задаёте (пусто) — запросы идут на тот же origin.
#
# Вариант B — API на поддомене:
#   VITE_API_URL=https://api.example.com
#   и в CORS_ORIGIN на сервере API укажите https://example.com

VITE_USE_AUTH_API=true
# VITE_API_URL=https://api.example.com
